{
  "manifest_version": 3,
  "name": "Node Capture",
  "version": "1.3.0",
  "description": "tracxlogis.com 페이지 노드를 다국어 스크린샷으로 캡쳐합니다.",
  "permissions": [
    "debugger",
    "downloads",
    "scripting",
    "sidePanel",
    "tabs"
  ],
  "host_permissions": [
    "*://*.tracxlogis.com/*",
    "*://*.tracxlogis.com:*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Node Capture",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["*://*.tracxlogis.com/*", "*://*.tracxlogis.com:*/*"],
      "js": ["main-world-bridge.js"],
      "run_at": "document_idle",
      "world": "MAIN"
    },
    {
      "matches": ["*://*.tracxlogis.com/*", "*://*.tracxlogis.com:*/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
