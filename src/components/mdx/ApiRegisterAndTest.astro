---
/**
 * SmartShip API 등록 및 연결 테스트 공통 섹션
 * - 등록하기 / 연결 테스트 단계
 * - 연결 테스트 실패 시 확인사항
 * - 문의처 안내
 *
 * 이 컴포넌트는 사이트별 '연결 정보 입력(3.2)' 직후에 배치합니다.
 *
 * @prop lang 현재 페이지 언어 (향후 다국어 지원용, 현재는 'ko'만 구현)
 */
import Callout from './Callout.astro';

interface Props {
  lang?: string;
}

const { lang = 'ko' } = Astro.props;
---

{lang === 'ko' && (
  <>
    <h3>등록 및 연결 테스트</h3>

    <ol>
      <li><strong>[등록하기]</strong> 버튼을 클릭합니다. 신규 등록 또는 정보를 수정한 경우 반드시 클릭해야 변경 사항이 시스템에 반영됩니다.</li>
      <li>등록 완료 후 <strong>[연결 테스트]</strong> 버튼을 클릭하여 API 통신이 정상적으로 이루어지는지 확인합니다.</li>
    </ol>

    <h4>연결 테스트 실패 시 확인사항</h4>

    <ol>
      <li>API 키 발급 시 스마트십 IP 정보가 정확하게 입력되었는지 확인합니다.</li>
      <li>Access Key 등 인증 정보가 각각 올바른 필드에 입력되었는지 확인합니다.</li>
      <li><strong>[등록하기]</strong> 또는 <strong>[수정하기]</strong> 버튼을 클릭하여 변경 사항을 시스템에 적용했는지 확인합니다.</li>
      <li>판매사이트 API 서버 일시적 장애 여부를 확인한 후 재시도합니다.</li>
    </ol>

    <Callout type="info" title="연속 실패 시 문의">
      <p>위 항목을 모두 확인한 후에도 연결 테스트가 계속 실패한다면 <a href="mailto:apihelp@tracxlogis.com">apihelp@tracxlogis.com</a>으로 다음 정보를 함께 보내주세요.</p>
      <ul>
        <li>판매자 로그인 이메일 또는 아이디</li>
        <li>연결하려는 사이트명 및 샵 ID</li>
        <li>스마트십 오류 화면 캡처</li>
        <li>쇼핑사이트 API 키 발급 정보 캡처</li>
      </ul>
    </Callout>
  </>
)}
