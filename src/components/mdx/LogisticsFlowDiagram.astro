---
import LogisticsFlowDiagramSvelte from '../svelte/LogisticsFlowDiagram.svelte';

interface Props {
  variant?: 'bypass' | 'fulfillment';
}

const { variant = 'bypass' } = Astro.props;
const lang = (Astro.params.lang as string) ?? 'ko';
---

<LogisticsFlowDiagramSvelte client:visible lang={lang} variant={variant} />
