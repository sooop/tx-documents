---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/common/Header.astro';
import Sidebar from '../components/navigation/Sidebar.astro';
import Breadcrumbs from '../components/navigation/Breadcrumbs.astro';
import TableOfContents from '../components/navigation/TableOfContents.astro';
import type { Lang } from '../lib/config';
import type { NavItem, BreadcrumbItem } from '../lib/navigation';
import type { MarkdownHeading } from 'astro';
import { t } from '../i18n/ui';
import '../styles/docs.css';

interface Props {
  title: string;
  description?: string;
  lang: Lang;
  currentSlug: string;
  navTree: NavItem[];
  breadcrumbs: BreadcrumbItem[];
  headings: MarkdownHeading[];
  draft?: boolean;
}

const {
  title,
  description,
  lang,
  currentSlug,
  navTree,
  breadcrumbs,
  headings,
  draft,
} = Astro.props;
---

<BaseLayout title={title} description={description} lang={lang}>
  <Header lang={lang} />
  <div class="docs-layout">
    <aside class="docs-sidebar">
      <Sidebar navTree={navTree} currentSlug={currentSlug} lang={lang} />
    </aside>
    <main class="docs-content">
      <Breadcrumbs items={breadcrumbs} lang={lang} />
      {draft && <div class="draft-banner">{t(lang, 'draft.label')}</div>}
      <article class="prose">
        <h1>{title}</h1>
        <slot />
      </article>
    </main>
    {
      headings.length > 0 && (
        <aside class="docs-toc">
          <TableOfContents headings={headings} lang={lang} />
        </aside>
      )
    }
  </div>
</BaseLayout>

<script>
  // .prose 내 일반 img(어노테이션 뷰어 외부)에 클릭 줌 기능 부여
  const backdrop = document.createElement('div');
  backdrop.setAttribute('role', 'dialog');
  backdrop.setAttribute('aria-modal', 'true');
  Object.assign(backdrop.style, {
    display: 'none',
    position: 'fixed',
    inset: '0',
    background: 'rgba(0,0,0,0.8)',
    zIndex: '1000',
    alignItems: 'center',
    justifyContent: 'center',
    padding: '1.5rem',
    backdropFilter: 'blur(2px)',
    cursor: 'zoom-out',
  });

  const modalImg = document.createElement('img');
  Object.assign(modalImg.style, {
    maxWidth: 'min(90vw, 1200px)',
    maxHeight: '90vh',
    objectFit: 'contain',
    borderRadius: '8px',
    boxShadow: '0 24px 60px rgba(0,0,0,0.6)',
    border: 'none',
    margin: '0',
  });

  backdrop.appendChild(modalImg);
  document.body.appendChild(backdrop);

  function openZoom(src: string, alt: string) {
    modalImg.src = src;
    modalImg.alt = alt;
    backdrop.style.display = 'flex';
    document.body.style.overflow = 'hidden';
  }

  function closeZoom() {
    backdrop.style.display = 'none';
    document.body.style.overflow = '';
  }

  backdrop.addEventListener('click', closeZoom);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeZoom();
  });

  // 외부 링크는 새 창으로 열기
  document.querySelectorAll<HTMLAnchorElement>('.prose a[href]').forEach((a) => {
    if (/^https?:\/\//.test(a.getAttribute('href') ?? '')) {
      a.target = '_blank';
      a.rel = 'noopener noreferrer';
    }
  });

  // .annotated-image 안에 있는 img는 ImageAnnotationViewer가 처리하므로 제외
  document.querySelectorAll<HTMLImageElement>('.prose img').forEach((img) => {
    if (img.closest('.annotated-image')) return;
    img.style.cursor = 'zoom-in';
    img.addEventListener('click', () => openZoom(img.src, img.alt));
  });
</script>
